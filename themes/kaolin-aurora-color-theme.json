	"tokenColors": [
		{
			"name": "Comment",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#454459"
			}
		},
		{
			"name": "Keyword",
			"scope": ["keyword", "keyword.control", "storage", "storage.type"],
			"settings": {
				"foreground": "#9D81BA"
			}
		},
		{
			"name": "Builtin / Support Function",
			"scope": [
				"support.function",
				"support.class",
				"support.type",
				"support.constant"
			],
			"settings": {
				"foreground": "#9D81BA"
			}
		},
		{
			"name": "Function / Method",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"support.function.any-method"
			],
			"settings": {
				"foreground": "#0BC9CF"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable",
				"meta.definition.variable.name",
				"entity.name.variable"
			],
			"settings": {
				"foreground": "#7CF083"
			}
		},
		{
			"name": "Parameters",
			"scope": ["variable.parameter", "meta.parameter"],
			"settings": {
				"foreground": "#D4D4D6"
			}
		},
		{
			"name": "Properties",
			"scope": [
				"variable.other.property",
				"meta.object-literal.key",
				"support.variable.property"
			],
			"settings": {
				"foreground": "#7CF083"
			}
		},
		{
			"name": "Type / Class / Interface",
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.namespace",
				"support.type"
			],
			"settings": {
				"foreground": "#62D2DB"
			}
		},
		{
			"name": "Constants",
			"scope": ["constant", "constant.language", "constant.character"],
			"settings": {
				"foreground": "#0D9C94"
			}
		},
		{
			"name": "Numbers",
			"scope": ["constant.numeric"],
			"settings": {
				"foreground": "#F5C791"
			}
		},
		{
			"name": "Boolean",
			"scope": ["constant.language.boolean"],
			"settings": {
				"foreground": "#F5C791"
			}
		},
		{
			"name": "Strings",
			"scope": ["string", "string.quoted", "string.template"],
			"settings": {
				"foreground": "#F5C791"
			}
		},
		{
			"name": "String Escape / Regex",
			"scope": [
				"constant.character.escape",
				"string.regexp",
				"string.regexp punctuation.definition.string.begin"
			],
			"settings": {
				"foreground": "#CD9575"
			}
		},
		{
			"name": "Documentation",
			"scope": ["comment.block.documentation", "string.quoted.docstring"],
			"settings": {
				"foreground": "#CD9575"
			}
		},
		{
			"name": "Preprocessor / Annotation",
			"scope": [
				"meta.preprocessor",
				"entity.name.tag",
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#E55C7A"
			}
		},
		{
			"name": "Operators and Punctuation",
			"scope": ["keyword.operator", "punctuation", "meta.brace"],
			"settings": {
				"foreground": "#D4D4D6"
			}
		},
		{
			"name": "Invalid",
			"scope": ["invalid", "invalid.deprecated"],
			"settings": {
				"foreground": "#E55C7A"
			}
		},
		{
			"name": "Warning Markup",
			"scope": ["markup.warning"],
			"settings": {
				"foreground": "#DBAC66"
			}
		},
		{
			"name": "Markdown Headings",
			"scope": [
				"markup.heading",
				"markup.heading punctuation.definition.heading"
			],
			"settings": {
				"foreground": "#9D81BA"
			}
		},
		{
			"name": "Markdown Emphasis",
			"scope": ["markup.italic", "markup.bold", "markup.bold markup.italic"],
			"settings": {
				"foreground": "#9D81BA"
			}
		},
		{
			"name": "Markdown Links",
			"scope": ["markup.underline.link", "string.other.link.title"],
			"settings": {
				"foreground": "#9D81BA"
			}
		},
		{
			"name": "Diff Inserted",
			"scope": ["markup.inserted", "meta.diff.header.to-file"],
			"settings": {
				"foreground": "#49BDB0"
			}
		},
		{
			"name": "Diff Changed",
			"scope": ["markup.changed", "meta.diff.header"],
			"settings": {
				"foreground": "#F5C791"
			}
		},
		{
			"name": "Diff Removed",
			"scope": ["markup.deleted", "meta.diff.header.from-file"],
			"settings": {
				"foreground": "#E55C7A"
			}
		}
	],
	"semanticTokenColors": {
		"namespace": "#E55C7A",
		"type": "#62D2DB",
		"class": "#62D2DB",
		"enum": "#62D2DB",
		"interface": "#62D2DB",
		"struct": "#62D2DB",
		"typeParameter": "#62D2DB",
		"parameter": "#D4D4D6",
		"variable": "#7CF083",
		"property": "#7CF083",
		"enumMember": "#0D9C94",
		"event": "#9D81BA",
		"function": "#0BC9CF",
		"method": "#0BC9CF",
		"macro": "#E55C7A",
		"keyword": "#9D81BA",
		"modifier": "#9D81BA",
		"comment": "#454459",
		"string": "#F5C791",
		"number": "#F5C791",
		"regexp": "#CD9575",
		"operator": "#D4D4D6",
		"decorator": "#E55C7A",
		"variable.readonly": "#0D9C94",
		"property.readonly": "#0D9C94",
		"parameter.readonly": "#0D9C94"
	},
	"kaolinMetadata": {
