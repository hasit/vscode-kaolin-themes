{
  "$schema": "vscode://schemas/color-theme",
  "name": "Kaolin Bubblegum",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#14171E",
    "editor.foreground": "#E6E6E8",
    "editorCursor.foreground": "#F2F2F2",
    "editor.selectionBackground": "#272C3A99",
