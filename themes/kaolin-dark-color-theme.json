	"tokenColors": [
		{
			"name": "Comment",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#545C5E"
			}
		},
		{
			"name": "Keyword",
			"scope": ["keyword", "keyword.control", "storage", "storage.type"],
			"settings": {
				"foreground": "#4D9391"
			}
		},
		{
			"name": "Builtin / Support Function",
			"scope": [
				"support.function",
				"support.class",
				"support.type",
				"support.constant"
			],
			"settings": {
				"foreground": "#80BCB6"
			}
		},
		{
			"name": "Function / Method",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"support.function.any-method"
			],
			"settings": {
				"foreground": "#80BCB6"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable",
				"meta.definition.variable.name",
				"entity.name.variable"
			],
			"settings": {
				"foreground": "#787096"
			}
		},
		{
			"name": "Parameters",
			"scope": ["variable.parameter", "meta.parameter"],
			"settings": {
				"foreground": "#D4D4D6"
			}
		},
		{
			"name": "Properties",
			"scope": [
				"variable.other.property",
				"meta.object-literal.key",
				"support.variable.property"
			],
			"settings": {
				"foreground": "#787096"
			}
		},
		{
			"name": "Type / Class / Interface",
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.namespace",
				"support.type"
			],
			"settings": {
				"foreground": "#CD9575"
			}
		},
		{
			"name": "Constants",
			"scope": ["constant", "constant.language", "constant.character"],
			"settings": {
				"foreground": "#AB98B5"
			}
		},
		{
			"name": "Numbers",
			"scope": ["constant.numeric"],
			"settings": {
				"foreground": "#CD5C60"
			}
		},
		{
			"name": "Boolean",
			"scope": ["constant.language.boolean"],
			"settings": {
				"foreground": "#CD5C60"
			}
		},
		{
			"name": "Strings",
			"scope": ["string", "string.quoted", "string.template"],
			"settings": {
				"foreground": "#65E6A7"
			}
		},
		{
			"name": "String Escape / Regex",
			"scope": [
				"constant.character.escape",
				"string.regexp",
				"string.regexp punctuation.definition.string.begin"
			],
			"settings": {
				"foreground": "#5D8272"
			}
		},
		{
			"name": "Documentation",
			"scope": ["comment.block.documentation", "string.quoted.docstring"],
			"settings": {
				"foreground": "#5D8272"
			}
		},
		{
			"name": "Preprocessor / Annotation",
			"scope": [
				"meta.preprocessor",
				"entity.name.tag",
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#9D81BA"
			}
		},
		{
			"name": "Operators and Punctuation",
			"scope": ["keyword.operator", "punctuation", "meta.brace"],
			"settings": {
				"foreground": "#D4D4D6"
			}
		},
		{
			"name": "Invalid",
			"scope": ["invalid", "invalid.deprecated"],
			"settings": {
				"foreground": "#CD5C60"
			}
		},
		{
			"name": "Warning Markup",
			"scope": ["markup.warning"],
			"settings": {
				"foreground": "#DBAC66"
			}
		},
		{
			"name": "Markdown Headings",
			"scope": [
				"markup.heading",
				"markup.heading punctuation.definition.heading"
			],
			"settings": {
				"foreground": "#4D9391"
			}
		},
		{
			"name": "Markdown Emphasis",
			"scope": ["markup.italic", "markup.bold", "markup.bold markup.italic"],
			"settings": {
				"foreground": "#80BCB6"
			}
		},
		{
			"name": "Markdown Links",
			"scope": ["markup.underline.link", "string.other.link.title"],
			"settings": {
				"foreground": "#9D81BA"
			}
		},
		{
			"name": "Diff Inserted",
			"scope": ["markup.inserted", "meta.diff.header.to-file"],
			"settings": {
				"foreground": "#35BF88"
			}
		},
		{
			"name": "Diff Changed",
			"scope": ["markup.changed", "meta.diff.header"],
			"settings": {
				"foreground": "#BC90D4"
			}
		},
		{
			"name": "Diff Removed",
			"scope": ["markup.deleted", "meta.diff.header.from-file"],
			"settings": {
				"foreground": "#CD5C60"
			}
		}
	],
	"semanticTokenColors": {
		"namespace": "#9D81BA",
		"type": "#CD9575",
		"class": "#CD9575",
		"enum": "#CD9575",
		"interface": "#CD9575",
		"struct": "#CD9575",
		"typeParameter": "#CD9575",
		"parameter": "#D4D4D6",
		"variable": "#787096",
		"property": "#787096",
		"enumMember": "#AB98B5",
		"event": "#80BCB6",
		"function": "#80BCB6",
		"method": "#80BCB6",
		"macro": "#9D81BA",
		"keyword": "#4D9391",
		"modifier": "#4D9391",
		"comment": "#545C5E",
		"string": "#65E6A7",
		"number": "#CD5C60",
		"regexp": "#5D8272",
		"operator": "#D4D4D6",
		"decorator": "#9D81BA",
		"variable.readonly": "#AB98B5",
		"property.readonly": "#AB98B5",
		"parameter.readonly": "#AB98B5"
	},
