	"tokenColors": [
		{
			"name": "Comment",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#41544B"
			}
		},
		{
			"name": "Keyword",
			"scope": ["keyword", "keyword.control", "storage", "storage.type"],
			"settings": {
				"foreground": "#40826D"
			}
		},
		{
			"name": "Builtin / Support Function",
			"scope": [
				"support.function",
				"support.class",
				"support.type",
				"support.constant"
			],
			"settings": {
				"foreground": "#90AEA1"
			}
		},
		{
			"name": "Function / Method",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"support.function.any-method"
			],
			"settings": {
				"foreground": "#90AEA1"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable",
				"meta.definition.variable.name",
				"entity.name.variable"
			],
			"settings": {
				"foreground": "#80BCB6"
			}
		},
		{
			"name": "Parameters",
			"scope": ["variable.parameter", "meta.parameter"],
			"settings": {
				"foreground": "#DCDED9"
			}
		},
		{
			"name": "Properties",
			"scope": [
				"variable.other.property",
				"meta.object-literal.key",
				"support.variable.property"
			],
			"settings": {
				"foreground": "#80BCB6"
			}
		},
		{
			"name": "Type / Class / Interface",
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.namespace",
				"support.type"
			],
			"settings": {
				"foreground": "#47BA99"
			}
		},
		{
			"name": "Constants",
			"scope": ["constant", "constant.language", "constant.character"],
			"settings": {
				"foreground": "#80BCB6"
			}
		},
		{
			"name": "Numbers",
			"scope": ["constant.numeric"],
			"settings": {
				"foreground": "#47BA99"
			}
		},
		{
			"name": "Boolean",
			"scope": ["constant.language.boolean"],
			"settings": {
				"foreground": "#47BA99"
			}
		},
		{
			"name": "Strings",
			"scope": ["string", "string.quoted", "string.template"],
			"settings": {
				"foreground": "#65E6A7"
			}
		},
		{
			"name": "String Escape / Regex",
			"scope": [
				"constant.character.escape",
				"string.regexp",
				"string.regexp punctuation.definition.string.begin"
			],
			"settings": {
				"foreground": "#65E6A7"
			}
		},
		{
			"name": "Documentation",
			"scope": ["comment.block.documentation", "string.quoted.docstring"],
			"settings": {
				"foreground": "#65E6A7"
			}
		},
		{
			"name": "Preprocessor / Annotation",
			"scope": [
				"meta.preprocessor",
				"entity.name.tag",
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#47BA99"
			}
		},
		{
			"name": "Operators and Punctuation",
			"scope": ["keyword.operator", "punctuation", "meta.brace"],
			"settings": {
				"foreground": "#DCDED9"
			}
		},
		{
			"name": "Invalid",
			"scope": ["invalid", "invalid.deprecated"],
			"settings": {
				"foreground": "#CD5C60"
			}
		},
		{
			"name": "Warning Markup",
			"scope": ["markup.warning"],
			"settings": {
				"foreground": "#DBAC66"
			}
		},
		{
			"name": "Markdown Headings",
			"scope": [
				"markup.heading",
				"markup.heading punctuation.definition.heading"
			],
			"settings": {
				"foreground": "#40826D"
			}
		},
		{
			"name": "Markdown Emphasis",
			"scope": ["markup.italic", "markup.bold", "markup.bold markup.italic"],
			"settings": {
				"foreground": "#90AEA1"
			}
		},
		{
			"name": "Markdown Links",
			"scope": ["markup.underline.link", "string.other.link.title"],
			"settings": {
				"foreground": "#9D81BA"
			}
		},
		{
			"name": "Diff Inserted",
			"scope": ["markup.inserted", "meta.diff.header.to-file"],
			"settings": {
				"foreground": "#49BDB0"
			}
		},
		{
			"name": "Diff Changed",
			"scope": ["markup.changed", "meta.diff.header"],
			"settings": {
				"foreground": "#CD9575"
			}
		},
		{
			"name": "Diff Removed",
			"scope": ["markup.deleted", "meta.diff.header.from-file"],
			"settings": {
				"foreground": "#CD5C60"
			}
		}
	],
