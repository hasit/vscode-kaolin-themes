	"tokenColors": [
		{
			"name": "Comment",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#697375"
			}
		},
		{
			"name": "Keyword",
			"scope": ["keyword", "keyword.control", "storage", "storage.type"],
			"settings": {
				"foreground": "#4EB8CA"
			}
		},
		{
			"name": "Builtin / Support Function",
			"scope": [
				"support.function",
				"support.class",
				"support.type",
				"support.constant"
			],
			"settings": {
				"foreground": "#91B9C7"
			}
		},
		{
			"name": "Function / Method",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"support.function.any-method"
			],
			"settings": {
				"foreground": "#91B9C7"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable",
				"meta.definition.variable.name",
				"entity.name.variable"
			],
			"settings": {
				"foreground": "#47BA99"
			}
		},
		{
			"name": "Parameters",
			"scope": ["variable.parameter", "meta.parameter"],
			"settings": {
				"foreground": "#D4D4D6"
			}
		},
		{
			"name": "Properties",
			"scope": [
				"variable.other.property",
				"meta.object-literal.key",
				"support.variable.property"
			],
			"settings": {
				"foreground": "#47BA99"
			}
		},
		{
			"name": "Type / Class / Interface",
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.namespace",
				"support.type"
			],
			"settings": {
				"foreground": "#B9C791"
			}
		},
		{
			"name": "Constants",
			"scope": ["constant", "constant.language", "constant.character"],
			"settings": {
				"foreground": "#4FA8A3"
			}
		},
		{
			"name": "Numbers",
			"scope": ["constant.numeric"],
			"settings": {
				"foreground": "#EF6787"
			}
		},
		{
			"name": "Boolean",
			"scope": ["constant.language.boolean"],
			"settings": {
				"foreground": "#EF6787"
			}
		},
		{
			"name": "Strings",
			"scope": ["string", "string.quoted", "string.template"],
			"settings": {
				"foreground": "#FBAED2"
			}
		},
		{
			"name": "String Escape / Regex",
			"scope": [
				"constant.character.escape",
				"string.regexp",
				"string.regexp punctuation.definition.string.begin"
			],
			"settings": {
				"foreground": "#BA667D"
			}
		},
		{
			"name": "Documentation",
			"scope": ["comment.block.documentation", "string.quoted.docstring"],
			"settings": {
				"foreground": "#BA667D"
			}
		},
		{
			"name": "Preprocessor / Annotation",
			"scope": [
				"meta.preprocessor",
				"entity.name.tag",
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#EF6787"
			}
		},
		{
			"name": "Operators and Punctuation",
			"scope": ["keyword.operator", "punctuation", "meta.brace"],
			"settings": {
				"foreground": "#D4D4D6"
			}
		},
		{
			"name": "Invalid",
			"scope": ["invalid", "invalid.deprecated"],
			"settings": {
				"foreground": "#E84C58"
			}
		},
		{
			"name": "Warning Markup",
			"scope": ["markup.warning"],
			"settings": {
				"foreground": "#F3C91F"
			}
		},
		{
			"name": "Markdown Headings",
			"scope": [
				"markup.heading",
				"markup.heading punctuation.definition.heading"
			],
			"settings": {
				"foreground": "#4EB8CA"
			}
		},
		{
			"name": "Markdown Emphasis",
			"scope": ["markup.italic", "markup.bold", "markup.bold markup.italic"],
			"settings": {
				"foreground": "#91B9C7"
			}
		},
		{
			"name": "Markdown Links",
			"scope": ["markup.underline.link", "string.other.link.title"],
			"settings": {
				"foreground": "#EF6787"
			}
		},
		{
			"name": "Diff Inserted",
			"scope": ["markup.inserted", "meta.diff.header.to-file"],
			"settings": {
				"foreground": "#4FA8A3"
			}
		},
		{
			"name": "Diff Changed",
			"scope": ["markup.changed", "meta.diff.header"],
			"settings": {
				"foreground": "#D7936D"
			}
		},
		{
			"name": "Diff Removed",
			"scope": ["markup.deleted", "meta.diff.header.from-file"],
			"settings": {
				"foreground": "#C74A4D"
			}
		}
	],
	"semanticTokenColors": {
		"namespace": "#EF6787",
		"type": "#B9C791",
		"class": "#B9C791",
		"enum": "#B9C791",
		"interface": "#B9C791",
		"struct": "#B9C791",
		"typeParameter": "#B9C791",
		"parameter": "#D4D4D6",
		"variable": "#47BA99",
		"property": "#47BA99",
		"enumMember": "#4FA8A3",
		"event": "#91B9C7",
		"function": "#91B9C7",
		"method": "#91B9C7",
		"macro": "#EF6787",
		"keyword": "#4EB8CA",
		"modifier": "#4EB8CA",
		"comment": "#697375",
		"string": "#FBAED2",
		"number": "#EF6787",
		"regexp": "#BA667D",
		"operator": "#D4D4D6",
		"decorator": "#EF6787",
		"variable.readonly": "#4FA8A3",
		"property.readonly": "#4FA8A3",
		"parameter.readonly": "#4FA8A3"
	},
	"kaolinMetadata": {
		"generatedFromRef": "fc0337582f36167b74cbdc86a48471092c8f3262",
