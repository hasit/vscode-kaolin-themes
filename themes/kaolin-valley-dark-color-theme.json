	"tokenColors": [
		{
			"name": "Comment",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#635C4A"
			}
		},
		{
			"name": "Keyword",
			"scope": ["keyword", "keyword.control", "storage", "storage.type"],
			"settings": {
				"foreground": "#49BDB0"
			}
		},
		{
			"name": "Builtin / Support Function",
			"scope": [
				"support.function",
				"support.class",
				"support.type",
				"support.constant"
			],
			"settings": {
				"foreground": "#53E6B5"
			}
		},
		{
			"name": "Function / Method",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"support.function.any-method"
			],
			"settings": {
				"foreground": "#7ED7E6"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable",
				"meta.definition.variable.name",
				"entity.name.variable"
			],
			"settings": {
				"foreground": "#EF6787"
			}
		},
		{
			"name": "Parameters",
			"scope": ["variable.parameter", "meta.parameter"],
			"settings": {
				"foreground": "#D4D4D6"
			}
		},
		{
			"name": "Properties",
			"scope": [
				"variable.other.property",
				"meta.object-literal.key",
				"support.variable.property"
			],
			"settings": {
				"foreground": "#EF6787"
			}
		},
		{
			"name": "Type / Class / Interface",
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.namespace",
				"support.type"
			],
			"settings": {
				"foreground": "#EED891"
			}
		},
		{
			"name": "Constants",
			"scope": ["constant", "constant.language", "constant.character"],
			"settings": {
				"foreground": "#EF6787"
			}
		},
		{
			"name": "Numbers",
			"scope": ["constant.numeric"],
			"settings": {
				"foreground": "#91F368"
			}
		},
		{
			"name": "Boolean",
			"scope": ["constant.language.boolean"],
			"settings": {
				"foreground": "#91F368"
			}
		},
		{
			"name": "Strings",
			"scope": ["string", "string.quoted", "string.template"],
			"settings": {
				"foreground": "#CEA2CA"
			}
		},
		{
			"name": "String Escape / Regex",
			"scope": [
				"constant.character.escape",
				"string.regexp",
				"string.regexp punctuation.definition.string.begin"
			],
			"settings": {
				"foreground": "#A9779C"
			}
		},
		{
			"name": "Documentation",
			"scope": ["comment.block.documentation", "string.quoted.docstring"],
			"settings": {
				"foreground": "#A9779C"
			}
		},
		{
			"name": "Preprocessor / Annotation",
			"scope": [
				"meta.preprocessor",
				"entity.name.tag",
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#9587DD"
			}
		},
		{
			"name": "Operators and Punctuation",
			"scope": ["keyword.operator", "punctuation", "meta.brace"],
			"settings": {
				"foreground": "#D4D4D6"
			}
		},
		{
			"name": "Invalid",
			"scope": ["invalid", "invalid.deprecated"],
			"settings": {
				"foreground": "#E84C58"
			}
		},
		{
			"name": "Warning Markup",
			"scope": ["markup.warning"],
			"settings": {
				"foreground": "#F3C91F"
			}
		},
		{
			"name": "Markdown Headings",
			"scope": [
				"markup.heading",
				"markup.heading punctuation.definition.heading"
			],
			"settings": {
				"foreground": "#49BDB0"
			}
		},
		{
			"name": "Markdown Emphasis",
			"scope": ["markup.italic", "markup.bold", "markup.bold markup.italic"],
			"settings": {
				"foreground": "#53E6B5"
			}
		},
		{
			"name": "Markdown Links",
			"scope": ["markup.underline.link", "string.other.link.title"],
			"settings": {
				"foreground": "#9D81BA"
			}
		},
		{
			"name": "Diff Inserted",
			"scope": ["markup.inserted", "meta.diff.header.to-file"],
			"settings": {
				"foreground": "#35BF88"
			}
		},
		{
			"name": "Diff Changed",
			"scope": ["markup.changed", "meta.diff.header"],
			"settings": {
				"foreground": "#EE7042"
			}
		},
		{
			"name": "Diff Removed",
			"scope": ["markup.deleted", "meta.diff.header.from-file"],
			"settings": {
				"foreground": "#E84C58"
			}
		}
	],
	"semanticTokenColors": {
		"namespace": "#9587DD",
		"type": "#EED891",
		"class": "#EED891",
		"enum": "#EED891",
		"interface": "#EED891",
		"struct": "#EED891",
		"typeParameter": "#EED891",
		"parameter": "#D4D4D6",
		"variable": "#EF6787",
		"property": "#EF6787",
		"enumMember": "#EF6787",
		"event": "#53E6B5",
		"function": "#7ED7E6",
		"method": "#7ED7E6",
		"macro": "#9587DD",
		"keyword": "#49BDB0",
		"modifier": "#49BDB0",
		"comment": "#635C4A",
		"string": "#CEA2CA",
		"number": "#91F368",
		"regexp": "#A9779C",
		"operator": "#D4D4D6",
		"decorator": "#9587DD",
		"variable.readonly": "#EF6787",
		"property.readonly": "#EF6787",
		"parameter.readonly": "#EF6787"
	},
